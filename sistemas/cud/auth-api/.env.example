# CUD auth-api — variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA commitar o .env real.

# PostgreSQL do Supabase local — schema isolado `cud`
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=cud"

# Supabase Auth (GoTrue) — autenticação dos usuários
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
JWT_SECRET=""

# Redis — cache da verificação de acesso (RN-CUD-021)
REDIS_URL="redis://localhost:6379"

# App
PORT=3002
