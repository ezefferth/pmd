# RH api — variáveis de ambiente (exemplo)

# PostgreSQL do Supabase local — schema isolado `rh`
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=rh"

# Sincronização RH→CUD (ficha funcional + setores)
CUD_API_URL="http://localhost:3001/api/v1"
CUD_SYNC_KEY=""   # deve bater com CUD_SYNC_KEY da auth-api

# App
PORT=3005
