# SPD web — variáveis de ambiente (exemplo)

# PostgreSQL do Supabase local — schema isolado `spd`
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=spd"

# CUD — autenticação e verificação de permissão (servidor e cidadão)
CUD_API_URL="http://localhost:3001/api/v1"

# Município ativo (tema da marca)
NEXT_PUBLIC_MUNICIPIO="dourados"

# Integração Betha (tributário)
BETHA_API_URL=""
BETHA_API_TIMEOUT_MS=5000

# Supabase Storage (documentos)
SUPABASE_URL="http://localhost:54321"
SUPABASE_SERVICE_ROLE_KEY=""
